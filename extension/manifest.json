{
  "manifest_version": 3,
  "name": "OnFrame",
  "version": "0.1.0",
  "description": "Edita fotos de anuncios do Mercado Livre pela pagina do produto.",
  "key": "",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.mercadolivre.com.br/*",
    "http://127.0.0.1:4765/*"
  ],
  "options_ui": {
    "page": "ui/options/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "OnFrame",
    "default_popup": "ui/popup/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.svg",
        "fonts/*.ttf",
        "vendor/phosphor/*"
      ],
      "matches": [
        "https://*.mercadolivre.com.br/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.mercadolivre.com.br/*"
      ],
      "js": [
        "core/icons.js",
        "core/detection.js",
        "core/shared.js",
        "modules/photos/model.js",
        "modules/photos/module.js",
        "modules/commerce/model.js",
        "modules/commerce/module.js",
        "core/module-registry.js",
        "core/content-shell.js",
        "content.js"
      ],
      "css": [
        "vendor/phosphor/phosphor.css",
        "styles/foundations.css",
        "styles/components.css",
        "modules/photos/styles.css",
        "modules/commerce/styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
